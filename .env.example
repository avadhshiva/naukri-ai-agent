# Email digest (company-site jobs only)
EMAIL_DIGEST_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email
SMTP_PASSWORD=your_app_password
MAIL_FROM=sender@example.com
MAIL_TO=recipient@example.com