NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_password
GROQ_API_KEY=your_groq_api_key
RESUME_PATH=/path/to/your/resume.pdf
HEADLESS=false
SEARCH_TITLES=Technical Delivery Manager
SEARCH_EXPERIENCES=7
SEARCH_LOCATIONS=Bengaluru,Chennai
SALARY_BAND=50-75 Lakhs
MAX_PAGES=1
